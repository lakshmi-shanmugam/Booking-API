                "exec": [
                  "console.log(\"fname var =\", fname);\r",
                  "console.log(\"lname var =\", lname);\r",
                  "console.log(\"response json =\", JSON.stringify(jsonData));\r",
                  "console.log(\"booking.firstname =\", jsonData?.booking?.firstname);\r",
                  "console.log(\"booking.lastname =\", jsonData?.booking?.lastname);\r",
                  "\r",
                  "\r",
                  "var fname=pm.variables.get(\"fname\");\r",
                  "var lname = pm.variables.get(\"lname\");\r",
                  "var jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"verify firstname\", function(){\r",
                  "    pm.expect(jsonData.booking.firstname).to.eql(fname);\r",
                  "});\r",
                  "pm.test(\"verify lastname\", function(){\r",
                  "    pm.expect(jsonData.booking.lastname).to.eql(lname);\r",
                  "});\r",
                  "\r",
                  "\r",
                  "// store booking id correctly\r",
                  "pm.environment.set(\"b_id\", jsonData.bookingid);\r",
                  "\r",
                  "// status code check\r",
                  "pm.test(\"Verify Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "//check firstname inside JSON\r",
                  "pm.test(\"Verify firstname is Lakshmi\", function () {\r",
                  "    pm.expect(jsonData.booking.firstname).to.eql(fname);\r",
                  "});\r",
                  "pm.test(\"Verify Content-Type is application/json\", function () {\r",
                  "    pm.response.to.have.header(\"Content-Type\", \"application/json; charset=utf-8\");\r",
                  "});\r",
                  "pm.test(\"Response time is less than 200ms\", function () {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
